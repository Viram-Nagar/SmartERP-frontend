            <div className="col-span-3 text-zinc-600 text-xs uppercase tracking-wider">
              Amount (₹)
            </div>
            <div className="col-span-3 text-zinc-600 text-xs uppercase tracking-wider">
              Narration
            </div>
            <div className="col-span-1" />
