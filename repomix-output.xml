    payee_payer: "",
    bank_name: "",
    notes: "",
  });
  const [error, setError] = useState("");
  const [success, setSuccess] = useState("");
  const [loading, setLoading] = useState(false);

  useEffect(() => {
    if (open) {
      setForm({
        ledger_id: "",
        cheque_type: "issued",
        cheque_number: "",
        cheque_date: today,
        amount: "",
        payee_payer: "",
        bank_name: "",
        notes: "",
      });
      setError("");
      setSuccess("");
    }
  }, [open]);

  const f = (key) => (e) => setForm((p) => ({ ...p, [key]: e.target.value }));

  const handleSubmit = async (e) => {
    e.preventDefault();
    setError("");
